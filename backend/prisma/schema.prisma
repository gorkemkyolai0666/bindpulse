generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Firm {
  id              String   @id @default(uuid())
  name            String
  phone           String   @default("")
  address         String   @default("")
  city            String   @default("")
  state           String   @default("")
  zipCode         String   @default("")
  totalWorkbenches Int     @default(2)
  timezone        String   @default("Europe/Istanbul")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users              User[]
  restorationProjects RestorationProject[]
  volumeItems        VolumeItem[]
  materialStocks     MaterialStock[]
  appointmentJobs    AppointmentJob[]
  workbenches        Workbench[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String   @default("artisan")
  firmId       String
  firm         Firm     @relation(fields: [firmId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ProjectStatus {
  intake
  assessment
  in_progress
  awaiting_materials
  quality_check
  ready
  delivered
  quoted
}

enum ProjectType {
  restoration
  rebinding
  gilding
  conservation
  custom_binding
  repair
}

model RestorationProject {
  id            String        @id @default(uuid())
  projectNumber String
  clientName    String
  projectType   ProjectType
  volumeCount   Int           @default(1)
  status        ProjectStatus @default(intake)
  benchName     String?
  notes         String?
  dueDate       DateTime?
  firmId        String
  firm          Firm          @relation(fields: [firmId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum VolumeCondition {
  excellent
  good
  fair
  poor
  critical
}

enum VolumeStatus {
  in_workshop
  awaiting_materials
  in_restoration
  completed
  returned
}

model VolumeItem {
  id             String          @id @default(uuid())
  title          String
  author         String?
  condition      VolumeCondition @default(fair)
  status         VolumeStatus    @default(in_workshop)
  estimatedHours Float?
  projectId      String?
  firmId         String
  firm           Firm            @relation(fields: [firmId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum MaterialCategory {
  leather
  paper
  thread
  adhesive
  gold_leaf
  cloth
  board
  tool
  chemical
}

model MaterialStock {
  id               String           @id @default(uuid())
  title            String
  materialCategory MaterialCategory
  pricePerUnit     Float            @default(0)
  stockQty         Int              @default(0)
  leadDays         Int              @default(7)
  status           String           @default("active")
  firmId           String
  firm             Firm             @relation(fields: [firmId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model AppointmentJob {
  id              String   @id @default(uuid())
  appointmentName String
  appointmentType String
  scheduledAt     DateTime
  status          String   @default("scheduled")
  benchName       String?
  volumeCount     Int?
  projectId       String?
  notes           String?
  firmId          String
  firm            Firm     @relation(fields: [firmId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Workbench {
  id          String   @id @default(uuid())
  title       String
  description String?
  artisan     String
  scheduledAt DateTime
  maxSlots    Int      @default(4)
  booked      Int      @default(0)
  status      String   @default("scheduled")
  firmId      String
  firm        Firm     @relation(fields: [firmId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
